{
  "name": "gateway-notificacao",
  "version": "1.0.0",
  "private": true,
  "description": "Gateway centralizado de notificacoes com Node.js, TypeScript, RabbitMQ e PostgreSQL.",
  "main": "dist/app.js",
  "scripts": {
    "prisma:push": "prisma db push",
    "build": "tsc -p tsconfig.json",
    "dev:api": "prisma db push && tsx watch src/app.ts",
    "dev:worker": "prisma db push && tsx watch src/worker.ts",
    "start:api": "prisma db push && node dist/app.js",
    "start:worker": "prisma db push && node dist/worker.js",
    "start": "node dist/app.js"
  },
  "dependencies": {
    "amqplib": "^0.10.5",
    "@prisma/client": "^6.12.0",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "prisma": "^6.12.0",
    "zod": "^4.0.14"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.7",
    "@types/express": "^5.0.3",
    "@types/node": "^24.1.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
