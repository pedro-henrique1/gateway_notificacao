NODE_ENV=development
PORT=3000
POSTGRES_USER=gateway
POSTGRES_PASSWORD=gateway
POSTGRES_DB=gateway_notifications

RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# Optional: explicit connection strings (will be used if set)
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
RABBITMQ_URL=amqp://${RABBITMQ_DEFAULT_USER}:${RABBITMQ_DEFAULT_PASS}@rabbitmq:5672

PORT=3000
APP_NAME=gateway-notificacao
NOTIFICATION_PROVIDER_MODE=random-fail
RABBITMQ_MAIN_QUEUE=notifications.main
RABBITMQ_RETRY_1M_QUEUE=notifications.retry.1m
RABBITMQ_RETRY_5M_QUEUE=notifications.retry.5m
RABBITMQ_RETRY_15M_QUEUE=notifications.retry.15m
RABBITMQ_DLQ_QUEUE=notifications.dlq
OUTBOX_POLL_INTERVAL_MS=5000
WORKER_PREFETCH=10